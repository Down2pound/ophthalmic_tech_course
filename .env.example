# Public URL of the deployed application, without a trailing slash.
# Example: https://course.example.com
PUBLIC_APP_URL=

# Stripe secret key. Use a test key until the full purchase flow has been verified.
STRIPE_SECRET_KEY=

# Stripe Price ID for the $699 one-time Ophthalmic Technician Foundations product.
# The Stripe price must be configured as a one-time payment, not recurring.
STRIPE_STANDARD_PRICE_ID=

# Long random value used to sign student login cookies.
# Generate at least 32 random bytes and never commit the real value.
SESSION_SECRET=

# Persistent location for encrypted-password account records and course progress.
# The hosting platform must mount durable storage at this location.
# Example: /var/data/optitech/course-data.json
DATA_FILE=./data/course-data.json
