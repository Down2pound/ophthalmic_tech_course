# Copy this file to .env for local development.
# Do not commit real Stripe secret keys or webhook secrets.

# Server-only key used to create Stripe Checkout Sessions.
STRIPE_SECRET_KEY=sk_test_replace_with_your_secret_key

# Optional public key. The current hosted Checkout flow does not require it,
# but keep it here for future Stripe.js/client-side features.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_publishable_key

# Used by the server to build Stripe success and cancel return URLs.
PUBLIC_APP_URL=http://localhost:3000

# Final paid-launch switch. Keep false until clinical review, database setup,
# webhook testing, and deployed smoke testing are complete.
ENABLE_PAID_ENROLLMENT=false

# Managed PostgreSQL connection string for durable purchases and enrollments.
DATABASE_URL=replace_with_managed_postgres_connection_string
DATABASE_SSL=true

# Used by the Stripe webhook receiver to verify events.
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_signing_secret

# Used by future passwordless sign-in sessions. Generate a long random value.
AUTH_SESSION_SECRET=replace_with_a_long_random_session_secret

# Used by the transactional email provider for sign-in links.
TRANSACTIONAL_EMAIL_API_URL=https://email-provider.example.com/send
TRANSACTIONAL_EMAIL_API_KEY=replace_with_your_email_provider_api_key
SIGN_IN_FROM_EMAIL="OptiTech Academy <noreply@example.com>"

# Temporary private token for protected practice-seat assignment requests.
PRACTICE_SEAT_ADMIN_TOKEN=replace_with_a_long_random_admin_token
