# Public URL of the deployed application, without a trailing slash.
PUBLIC_APP_URL=https://course.example.com

# Stripe live or test credentials. Use test mode until the full purchase flow passes.
STRIPE_SECRET_KEY=
STRIPE_STANDARD_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_ALLOW_PROMOTION_CODES=true
STRIPE_AUTOMATIC_TAX=false

# Long random value used to sign student login cookies.
SESSION_SECRET=

# Persistent writable location for accounts, purchases, invitations, and progress.
DATA_FILE=./data/course-data.json

# Transactional email through Resend. Verify the EMAIL_FROM domain first.
RESEND_API_KEY=
EMAIL_FROM=OptiTech Academy <course@example.com>
SUPPORT_EMAIL=
SALES_NOTIFICATION_EMAIL=

# Customer-facing business information used by policies and support.
BUSINESS_NAME=OptiTech Academy
BUSINESS_LEGAL_NAME=
BUSINESS_ADDRESS=
